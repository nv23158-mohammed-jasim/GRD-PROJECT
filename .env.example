# Copy this file to .env and fill in the missing values

# Get this from: console.neon.tech → your project → Connection Details → copy "Connection string"
DATABASE_URL=

# Get these from: console.cloud.google.com → APIs & Services → Credentials → your OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string, e.g. run this in terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Already set — this is your Render backend URL
GOOGLE_CALLBACK_URL=https://grd-project-server.onrender.com/auth/google/callback

# Already set — this is your Amplify frontend URL
FRONTEND_URL=https://main.dfi1vofcktrh3.amplifyapp.com
